<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="xCapture" />
		<Option pch_mode="0" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Linux_Debug">
				<Option platforms="Unix;" />
				<Option output="../bin/xCapture" prefix_auto="1" extension_auto="1" />
				<Option object_output=".objs_ld" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectCompilerOptionsRelation="1" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-std=gnu++20" />
					<Add option="-g" />
					<Add option="`wx-config --version=3.3 --cflags`" />
					<Add option="-Winvalid-pch" />
					<Add option="-DWX_PRECOMP" />
					<Add option="-DLINUX" />
					<Add option="-D__WXDEBUG__" />
					<Add option='-D__cdecl=&quot;&quot;' />
					<Add directory="include" />
					<Add directory="../xCapture" />
					<Add directory="../include" />
					<Add directory="../shared" />
					<Add directory="../shared/utils" />
					<Add directory="../dependencies" />
					<Add directory="../dependencies/pugixml/src" />
					<Add directory="../dependencies/spdlog/include" />
				</Compiler>
				<Linker>
					<Add option="-ldl -lX11" />
					<Add option="`wx-config --version=3.3 --libs std`" />
					<Add option="-rdynamic" />
				</Linker>
			</Target>
			<Target title="Linux_Release">
				<Option platforms="Unix;" />
				<Option output="../bin/xCapture" prefix_auto="1" extension_auto="1" />
				<Option object_output=".objs_lr" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-std=gnu++20" />
					<Add option="-Wall" />
					<Add option="`wx-config --version=3.3 --cflags`" />
					<Add option="-Winvalid-pch" />
					<Add option="-DWX_PRECOMP" />
					<Add option="-DLINUX" />
					<Add option="-DNDEBUG" />
					<Add option="-D__cdecl=&apos;&apos;" />
					<Add directory="include" />
					<Add directory="../xCapture" />
					<Add directory="../include" />
					<Add directory="../shared" />
					<Add directory="../shared/utils" />
					<Add directory="../dependencies" />
					<Add directory="../dependencies/pugixml/src" />
					<Add directory="../dependencies/spdlog/include" />
				</Compiler>
				<Linker>
					<Add option="-ldl -lX11" />
					<Add option="`wx-config --version=3.3 --libs std`" />
					<Add option="-rdynamic" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-fno-strict-aliasing" />
			<Add option="-Wno-unused-local-typedefs" />
			<Add option="-DwxUSE_UNICODE" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="$(#wx)/include" />
		</ResourceCompiler>
		<Unit filename="../common/xCaptureBaseApp.cpp" />
		<Unit filename="../common/xCaptureBaseApp.h" />
		<Unit filename="../common/xlStackWalker.h" />
		<Unit filename="../shared/ui/setup/IPEntryDialog.cpp" />
		<Unit filename="../shared/ui/shared/utils/xCaptureTimer.cpp" />
		<Unit filename="../shared/ui/shared/utils/xCaptureTimer.h" />
		<Unit filename="../shared/ui/setup/IPEntryDialog.h" />
		<Unit filename="../shared/utils/JobPool.cpp" />
		<Unit filename="../shared/utils/JobPool.h" />
		<Unit filename="../shared/utils/TraceLog.cpp" />
		<Unit filename="../shared/utils/TraceLog.h" />
		<Unit filename="../dependencies/pugixml/src/pugixml.cpp" />
		<Unit filename="../shared/utils/ip_utils.cpp" />
		<Unit filename="../shared/utils/ip_utils.h" />
		<Unit filename="../shared/utils/string_utils.cpp" />
		<Unit filename="../shared/utils/string_utils.h" />
		<Unit filename="../shared/xCaptureVersion.cpp" />
		<Unit filename="../shared/xCaptureVersion.h" />
		<Unit filename="../json/wxJSON/json_defs.h" />
		<Unit filename="../json/wxJSON/jsonreader.cpp" />
		<Unit filename="../json/wxJSON/jsonreader.h" />
		<Unit filename="../json/wxJSON/jsonval.cpp" />
		<Unit filename="../json/wxJSON/jsonval.h" />
		<Unit filename="ResultDialog.cpp" />
		<Unit filename="ResultDialog.h" />
		<Unit filename="UniverseEntryDialog.cpp" />
		<Unit filename="UniverseEntryDialog.h" />
		<Unit filename="resource.rc">
			<Option compilerVar="WINDRES" />
			<Option target="MinGW_Debug" />
			<Option target="MinGW_Release" />
			<Option target="64bit_MinGW_Release" />
		</Unit>
		<Unit filename="wxsmith/ResultDialog.wxs" />
		<Unit filename="wxsmith/UniverseEntryDialog.wxs" />
		<Unit filename="wxsmith/xCaptureframe.wxs" />
		<Unit filename="xCaptureApp.cpp" />
		<Unit filename="xCaptureApp.h" />
		<Unit filename="xCaptureMain.cpp" />
		<Unit filename="xCaptureMain.h" />
		<Extensions>
			<lib_finder disable_auto="1" />
			<wxsmith version="1">
				<gui name="wxWidgets" src="xCaptureApp.cpp" main="xCaptureFrame" init_handlers="necessary" language="CPP" />
				<resources>
					<wxFrame wxs="wxsmith/xCaptureframe.wxs" src="xCaptureMain.cpp" hdr="xCaptureMain.h" fwddecl="0" i18n="1" name="xCaptureFrame" language="CPP" />
					<wxDialog wxs="wxsmith/UniverseEntryDialog.wxs" src="UniverseEntryDialog.cpp" hdr="UniverseEntryDialog.h" fwddecl="0" i18n="1" name="UniverseEntryDialog" language="CPP" />
					<wxDialog wxs="wxsmith/ResultDialog.wxs" src="ResultDialog.cpp" hdr="ResultDialog.h" fwddecl="0" i18n="1" name="ResultDialog" language="CPP" />
				</resources>
			</wxsmith>
		</Extensions>
	</Project>
</CodeBlocks_project_file>
